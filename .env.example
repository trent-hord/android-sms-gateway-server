PORT=3000
HTTP__API__PATH=/api

# public lets phones register without a server token. private requires
# Authorization: Bearer <GATEWAY__PRIVATE_TOKEN> for new device registration.
GATEWAY__MODE=private
GATEWAY__PRIVATE_TOKEN=change-me

DATABASE__HOST=localhost
DATABASE__PORT=3306
DATABASE__USER=your_database_user
DATABASE__PASSWORD=your_database_password
DATABASE__DATABASE=your_database_name
DATABASE__MAX_OPEN_CONNS=4

# Optional. Enables /3rdparty/v1/auth/token JWT issuing and Bearer auth.
JWT__SECRET=change-this-to-a-long-random-secret
JWT__ISSUER=sms-gateway-node
JWT__ACCESS_TTL=15m
JWT__REFRESH_TTL=30d

OTP__TTL=300
